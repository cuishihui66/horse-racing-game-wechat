page {
  min-height: 100vh;
  background: linear-gradient(180deg, #08111f 0%, #0f172a 100%);
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  display: grid;
  gap: 24rpx;
}

.hero-card,
.message-card,
.race-card {
  background: rgba(10, 18, 33, 0.92);
  border-radius: 32rpx;
  padding: 30rpx;
  color: #f8fbff;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.22);
}

.kicker,
.section-title {
  font-size: 22rpx;
  letter-spacing: 8rpx;
  color: #36d3c9;
}

.title {
  display: block;
  margin-top: 14rpx;
  font-size: 54rpx;
  font-weight: 800;
}

.status-title {
  display: block;
  margin-top: 16rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #ffd36f;
}

.phase-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #c7d6ee;
}

.message-input {
  width: 100%;
  min-height: 140rpx;
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.06);
  color: #f8fbff;
  box-sizing: border-box;
}

.message-button {
  margin-top: 18rpx;
  border-radius: 999rpx;
  background: rgba(54, 211, 201, 0.16);
  color: #dffffa;
}

.race-stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.stat-pill {
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.06);
  text-align: center;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #9fb5d3;
}

.stat-value {
  display: block;
  margin-top: 8rpx;
  font-size: 38rpx;
  font-weight: 800;
}

.progress-bar {
  margin-top: 24rpx;
  height: 18rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #36d3c9 0%, #ff9f5a 100%);
  border-radius: 999rpx;
}

.tap-button {
  margin-top: 28rpx;
  padding: 44rpx 24rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #ffb066 0%, #ff8a3d 100%);
  color: #201204;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tap-button[disabled] {
  background: rgba(255, 255, 255, 0.08);
  color: #c7d6ee;
}

.tap-button-active {
  transform: scale(0.97);
}

.tap-title {
  font-size: 52rpx;
  font-weight: 800;
}

.tap-subtitle {
  font-size: 26rpx;
  opacity: 0.88;
}
