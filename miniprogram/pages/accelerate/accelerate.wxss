/* miniprogram/pages/accelerate/accelerate.wxss */
page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  overflow: hidden;
}

.container {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
  height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
}

.header-section {
  width: 100%;
  text-align: center;
}

.title {
  font-size: 60rpx;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 20rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 2rpx;
}

.status-bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.tap-count {
  font-size: 34rpx;
  color: #fbbf24;
  font-weight: bold;
  background: rgba(251, 191, 36, 0.2);
  padding: 10rpx 30rpx;
  border-radius: 50rpx;
  margin-bottom: 10rpx;
}

.game-status {
  font-size: 24rpx;
  color: #ffffff;
  opacity: 0.8;
}

.accelerate-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  justify-content: center;
  width: 100%;
}

.accelerate-button-wrapper {
  position: relative;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: radial-gradient(circle, #f093fb 0%, #f5576c 100%);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: 
    0 20rpx 40rpx rgba(245, 87, 108, 0.4),
    inset 0 -10rpx 20rpx rgba(0, 0, 0, 0.2);
  transition: all 0.1s ease;
  animation: pulse 2s infinite;
  margin: 20rpx 0;
}

.button-active {
  transform: scale(0.95);
  box-shadow: 
    0 10rpx 20rpx rgba(245, 87, 108, 0.3),
    inset 0 -5rpx 10rpx rgba(0, 0, 0, 0.1);
  background: radial-gradient(circle, #f5576c 0%, #f093fb 100%);
}

.horse-container {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 20rpx;
}

.horse-icon {
  width: 160rpx;
  height: 160rpx;
  transition: transform 0.2s ease;
}

.tap-effect {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  animation: tapEffect 0.3s ease-out;
}

.button-text {
  color: white;
  font-size: 44rpx;
  font-weight: 800;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
  margin-top: 10rpx;
}

.instructions-section {
  width: 100%;
  text-align: center;
}

.instructions {
  font-size: 28rpx;
  color: #ffffff;
  opacity: 0.9;
  margin-bottom: 30rpx;
}

.progress-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15rpx;
}

.progress-bar {
  width: 80%;
  height: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #f093fb 0%, #f5576c 100%);
  border-radius: 10rpx;
  transition: width 0.3s ease;
  position: relative;
}

.progress-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

/* Animations */
@keyframes pulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 
      0 20rpx 40rpx rgba(245, 87, 108, 0.4),
      inset 0 -10rpx 20rpx rgba(0, 0, 0, 0.2);
  }
  50% {
    transform: scale(1.02);
    box-shadow: 
      0 25rpx 50rpx rgba(245, 87, 108, 0.5),
      inset 0 -5rpx 15rpx rgba(0, 0, 0, 0.1);
  }
}

@keyframes tapEffect {
  0% {
    transform: scale(0.8);
    opacity: 1;
  }
  100% {
    transform: scale(1.2);
    opacity: 0;
  }
}

/* 页面切换动画 */
.container {
  animation: slideIn 0.5s ease-out;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(50rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
