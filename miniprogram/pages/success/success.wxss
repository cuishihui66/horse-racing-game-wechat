page {
  min-height: 100vh;
  background: linear-gradient(180deg, #08111f 0%, #0f172a 100%);
}

.page {
  min-height: 100vh;
  display: grid;
  place-items: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.card {
  width: 100%;
  padding: 52rpx 40rpx;
  border-radius: 36rpx;
  background: rgba(10, 18, 33, 0.92);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 22rpx 60rpx rgba(0, 0, 0, 0.24);
  color: #f8fbff;
}

.kicker {
  font-size: 22rpx;
  color: #36d3c9;
  letter-spacing: 10rpx;
}

.title {
  display: block;
  margin-top: 16rpx;
  font-size: 62rpx;
  font-weight: 800;
}

.subtitle {
  display: block;
  margin-top: 24rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #c7d6ee;
}

.session-id {
  display: inline-block;
  margin-top: 28rpx;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  color: #9fb5d3;
  font-size: 24rpx;
}

.primary-button {
  margin-top: 36rpx;
  background: linear-gradient(135deg, #ffb066 0%, #ff8a3d 100%);
  color: #201204;
  font-size: 32rpx;
  font-weight: 800;
  border-radius: 999rpx;
}
